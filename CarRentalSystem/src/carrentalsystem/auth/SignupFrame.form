              <AuxValues>
                <AuxValue name="JavaCodeGenerator_CreateCodeCustom" type="java.lang.String" value="new javax.swing.JButton() {&#xa;    @Override&#xa;    protected void paintComponent(java.awt.Graphics g) {&#xa;        java.awt.Graphics2D g2 = (java.awt.Graphics2D) g.create();&#xa;        g2.setRenderingHint(java.awt.RenderingHints.KEY_ANTIALIASING, java.awt.RenderingHints.VALUE_ANTIALIAS_ON);&#xa;        &#xa;        // Change color slightly when hovering/clicking for a modern feel&#xa;        if (getModel().isPressed()) {&#xa;            g2.setColor(new java.awt.Color(50, 50, 50)); // Dark grey when clicked&#xa;        } else if (getModel().isRollover()) {&#xa;            g2.setColor(new java.awt.Color(30, 30, 30)); // Slightly lighter black on hover&#xa;        } else {&#xa;            g2.setColor(getBackground()); // Default Black&#xa;        }&#xa;        &#xa;        g2.fillRoundRect(0, 0, getWidth(), getHeight(), 30, 30);&#xa;        g2.dispose();&#xa;        &#xa;        super.paintComponent(g);&#xa;    }&#xa;    &#xa;    @Override&#xa;    public void setBorder(javax.swing.border.Border border) {&#xa;        // Prevents square border from appearing&#xa;    }&#xa;}&#xa;"/>
