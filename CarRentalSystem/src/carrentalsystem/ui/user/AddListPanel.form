nts = {(getHeight() / 2) - 2, (getHeight() / 2) + 3, (getHeight() / 2) - 2};&#xa;        g2.setColor(new java.awt.Color(100, 100, 100)); // Dark grey arrow&#xa;        g2.fillPolygon(xPoints, yPoints, 3);&#xa;&#xa;        g2.dispose();&#xa;        super.paintComponent(g);&#xa;    }&#xa;}"/>
