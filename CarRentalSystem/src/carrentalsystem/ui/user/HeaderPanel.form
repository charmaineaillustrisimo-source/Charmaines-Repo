        <AuxValue name="JavaCodeGenerator_CreateCodeCustom" type="java.lang.String" value="new javax.swing.JButton() {&#xa;    @Override&#xa;    protected void paintComponent(java.awt.Graphics g) {&#xa;        super.paintComponent(g); // Draws the original bell icon&#xa;        &#xa;        if (unreadCount &gt; 0) {&#xa;            java.awt.Graphics2D g2 = (java.awt.Graphics2D) g.create();&#xa;            // Makes the red dot smooth&#xa;            g2.setRenderingHint(java.awt.RenderingHints.KEY_ANTIALIASING, java.awt.RenderingHints.VALUE_ANTIALIAS_ON);&#xa;            g2.setColor(java.awt.Color.RED);&#xa;&#xa;            // Draws the red dot at the top-right corner of your 50x51 button&#xa;            g2.fillOval(getWidth() - 15, 5, 12, 12); &#xa;            g2.dispose();&#xa;        }&#xa;    }&#xa;}"/>
